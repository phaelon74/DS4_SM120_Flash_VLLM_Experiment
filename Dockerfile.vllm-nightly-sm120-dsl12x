FROM vllm/vllm-openai:deepseekv4-cu130

ARG DEBIAN_FRONTEND=noninteractive

# Same OS deps as Dockerfile.vllm-nightly-sm120 -- mirror those so the dsl12x
# container is a strict superset of the production container in terms of
# system tooling. Diverging here would mean dsl12x kernel debug sessions
# could not use ncu / cuda-libraries-dev tools available in production.
RUN apt-get update && apt-get install -y --no-install-recommends \
    cuda-libraries-dev-13-0 \
    cuda-nsight-compute-13-0 \
    && rm -rf /var/lib/apt/lists/*

# CuTe DSL toolchain. b12x is installed for parity with production (the
# patcher's b12x MoE opt-in path needs it) but dsl12x kernels do NOT
# import from b12x. nvidia-cutlass-dsl-libs-cu13 is the actual toolchain
# dsl12x requires.
RUN python3 -m pip install --no-cache-dir --no-deps \
    b12x==0.7.0 \
    nvidia-cutlass-dsl-libs-cu13==4.4.2

# Apply the same DeepSeek V4 patcher as production. dsl12x adds a new branch
# inside _sm120_flash_mla_sparse_prefill_fwd; the branch is gated by
# DG_SM120_DSL12X_PREFILL=1 (off by default so this Dockerfile remains a
# safe drop-in for production use, with dsl12x activated only via the
# sibling docker-compose.dsl12x.yml service).
COPY docker/patch_vllm_deepseekv4.py /tmp/patch_vllm_deepseekv4.py
RUN python3 /tmp/patch_vllm_deepseekv4.py

ENV CUDA_HOME=/usr/local/cuda
ENV TORCH_CUDA_ARCH_LIST=12.0
ENV CUTE_DSL_ARCH=sm_120a
ENV B12X_CUTE_COMPILE_CACHE_DIR=/tmp/b12x_cute_cache

# dsl12x JIT cache directory. Separate from b12x's so the two libraries
# never share a cache key namespace; debugging dsl12x compile failures
# should not require clearing b12x's cache.
ENV DSL12X_CUTE_COMPILE_CACHE_DIR=/tmp/dsl12x_cute_cache

ENV VLLM_TARGET_DEVICE=cuda
ENV PYTHONUNBUFFERED=1

WORKDIR /workspace
